# ─────────────────────────────────────────────
# YP LABS — Environment Configuration
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:3000

# Database (Supabase / Neon Postgres)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DB_SSL=true

# JWT Auth
JWT_SECRET=replace_with_long_random_secret_min_64_chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=replace_with_another_long_random_secret
REFRESH_TOKEN_EXPIRES_IN=30d

# File Storage (Cloudflare R2 or S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=yp-labs-files
R2_PUBLIC_URL=https://files.accessyplabs.com

# Email (Nodemailer — SMTP or SendGrid)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
EMAIL_FROM=no-reply@accessyplabs.com
EMAIL_FROM_NAME=YP Labs

# Stripe (payments & installment billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# E-Signature (Dropbox Sign)
DROPBOX_SIGN_API_KEY=
DROPBOX_SIGN_CLIENT_ID=

# Realtime (Supabase Realtime or Pusher)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=us2

# Internal Notifications (n8n / Slack webhook)
SLACK_WEBHOOK_URL=

# Admin
MASTER_ADMIN_EMAIL=admin@accessyplabs.com
