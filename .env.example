# ─────────────────────────────────────────────
# YP LABS — Environment Configuration
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:3000

# Database (Supabase / Neon Postgres)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DB_SSL=true

# JWT Auth
JWT_SECRET=replace_with_long_random_secret_min_64_chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=replace_with_another_long_random_secret
REFRESH_TOKEN_EXPIRES_IN=30d

# File Storage (Cloudinary signed uploads)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Stripe (payments & installment billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
